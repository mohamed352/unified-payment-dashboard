# Server
PORT=3000
BASE_URL=http://localhost:3000
PAYMENT_SESSION_SECRET=change_this_to_a_32_byte_random_string

# Gemini AI (for generating country-specific customer details)
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-flash-latest

# Payone Direct Post credentials
PAYONE_MERCHANT_ID=your_merchant_id
PAYONE_AUTH_TOKEN=your_auth_token
PAYONE_PAYMENT_URL=https://payone.example/payment
PAYONE_VERSION=2.0
PAYONE_ITEM_ID=your_item_id
PAYONE_CURRENCY_ISO=682
PAYONE_CHANNEL=0
PAYONE_THEME_ID=default

# PayTabs Own Form credentials
PAYTABS_PROFILE_ID=your_profile_id
PAYTABS_SERVER_KEY=your_server_key
PAYTABS_REGION=sa

# Payzaty Direct Pay credentials
PAYZATY_ACCOUNT_NO=your_account_no
PAYZATY_SECRET_KEY=your_secret_key
PAYZATY_ENV=sandbox

# Optional Redis for Vercel/serverless deployments
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
